Bootstrap: docker
From: python:3.9-slim

%files
    # Copy the mlruns directory so the container has the MLflow registry
    requirements.txt /app/requirements.txt
    app.py /app/app.py
    mlruns /app/mlruns

%post
    cd /app
    pip install --no-cache-dir -r requirements.txt

%startscript
    cd /app
    exec uvicorn app:app --host 0.0.0.0 --port 8000

%labels
    Author Jorge
    Version v1.0
    Description Financial Sentiment API with MLflow Tracking